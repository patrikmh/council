# One key for the whole table: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# The panel — comma-separated OpenRouter slugs, optional "|Display Name".
# Browse slugs at https://openrouter.ai/models
ROUNDTABLE_PANEL=anthropic/claude-sonnet-4.6,openai/gpt-5.2,google/gemini-3.1-pro,z-ai/glm-5.1,moonshotai/kimi-k2.5

# Framer + summarizer
FRAMER_MODEL=anthropic/claude-sonnet-5

# News council — four voices picked for viewpoint diversity, separate
# from the poll panel. The coordinator runs the desk + judging and
# deliberately does not sit on the panel.
NEWS_PANEL=openai/gpt-5.5,x-ai/grok-4.3,z-ai/glm-5.2,mistralai/mistral-medium-3-5
NEWS_COORDINATOR_MODEL=anthropic/claude-sonnet-5
